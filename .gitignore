# Secrets (tokens should be set as env vars, but ignore .env as a safety net)
.env

# Sensitive team config (real files contain PII / internal IDs — see .example.json)
agents/weekly-team-update/data/team-config.json
agents/sprint-review/data/sprint-config.json
agents/jira-qe-story/data/qe-config.json
agents/jira-sprint-tickets-updater/data/config.json
agents/slack-channels-analyzer/data/config.json
agents/jira-add-missing-activity-type/data/config.json

# Agent cache (contents only, keep .gitkeep)
agents/*/data/cache/*
!agents/*/data/cache/.gitkeep

# Agent output (generated reports)
agents/*/data/output/*.md
agents/*/data/output/*.json

# Node
node_modules/

# OS
.DS_Store

# Copy this file to .env and fill in your actual tokens.
# NEVER commit .env to version control.

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_PAT=your_github_token_here

# GitLab Personal Access Token
# Get from: https://gitlab.cee.redhat.com/-/profile/personal_access_tokens
# Required scopes: api, read_api, read_repository
GITLAB_PAT=your_gitlab_token_here
GITLAB_PERSONAL_ACCESS_TOKEN=$GITLAB_PAT

# Atlassian API Token (for Jira Cloud)
# Get from: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_OAUTH_TOKEN=your_atlassian_token_here

  },
  "github_link_fields": ["remote_links", "description"],
  "projects": {
    "CNV": {
      "workflows": {
        "standard": {
          "issue_types": [
            "Story",
            "Task",
            "Sub-task",
            "Bug",
            "Feature Request"
          ],
          "transition_rules": [
            {
              "from": "In Progress",
              "to": "Dev Complete",
              "condition": "all_links_resolved",
              "transition_id": "51",
              "description": "All linked PRs merged / issues closed"
            }
          ]
        }
      }
    },

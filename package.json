{
  "name": "ninja-agents",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "weekly:generate": "tsx agents/weekly-team-update/scripts/generate-weekly-report.ts",
    "weekly:validate": "tsx agents/weekly-team-update/scripts/validate-report-links.ts",
    "weekly:test": "vitest run --dir agents/weekly-team-update",
    "sprint-review:generate": "tsx agents/sprint-review/scripts/generate-sprint-review.ts",
    "sprint-review:test": "vitest run --dir agents/sprint-review",
    "context:audit": "tsx agents/repo-contextification/scripts/audit-repo.ts",
    "context:audit:dry-run": "tsx agents/repo-contextification/scripts/audit-repo.ts --dry-run",
    "context:validate": "tsx agents/repo-contextification/scripts/validate-output.ts",
    "context:test": "vitest run --dir agents/repo-contextification",
    "sprint-planning-analysis:generate": "tsx agents/sprint-planning-analysis/scripts/generate-sprint-planning-analysis.ts",
    "sprint-planning-analysis:test": "vitest run --dir agents/sprint-planning-analysis",
    "jira-qe-story:preview": "tsx agents/jira-qe-story/scripts/format-qe-preview.ts",
    "jira-qe-story:create": "tsx agents/jira-qe-story/scripts/create-jira-issue.ts",
    "jira-qe-story:test": "vitest run --dir agents/jira-qe-story",
    "jira-sprint-tickets-updater:generate": "tsx agents/jira-sprint-tickets-updater/scripts/generate-ticket-updates.ts",
    "jira-sprint-tickets-updater:validate": "tsx agents/jira-sprint-tickets-updater/scripts/validate-output.ts",
    "jira-sprint-tickets-updater:test": "vitest run --dir agents/jira-sprint-tickets-updater",
    "slack-channels-analyzer:generate": "tsx agents/slack-channels-analyzer/scripts/generate-report.ts",
    "slack-channels-analyzer:validate": "tsx agents/slack-channels-analyzer/scripts/validate-output.ts",
    "slack-channels-analyzer:test": "vitest run --dir agents/slack-channels-analyzer",
    "jira-add-missing-activity-type:classify": "tsx agents/jira-add-missing-activity-type/scripts/classify-tickets.ts",
    "jira-add-missing-activity-type:apply": "tsx agents/jira-add-missing-activity-type/scripts/apply-activity-types.ts",
    "jira-add-missing-activity-type:test": "vitest run --dir agents/jira-add-missing-activity-type"
  },
  "dependencies": {
    "@slack/web-api": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.0"
  }
}

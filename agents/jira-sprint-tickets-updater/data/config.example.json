{
  "jira": {
    "cloud_id": "your-site.atlassian.net",
    "board_id": 12345
  },
  "sprint": {
    "name_pattern": "Your Team Sprint"
  },
  "github_link_fields": ["remote_links", "description"],
  "protected_statuses": [
    "MODIFIED",
    "Dev Complete",
    "ON_QA",
    "Testing",
    "Verified",
    "Release Pending",
    "Closed"
  ],
  "engineers": [
    {
      "name": "Jane Doe",
      "jira_account_id": "712020:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
    }
  ],
  "projects": {
    "PROJ": {
      "workflows": {
        "standard": {
          "issue_types": ["Story", "Task", "Sub-task", "Epic"],
          "transition_rules": [
            {
              "from": "In Progress",
              "to": "Dev Complete",
              "condition": "all_links_resolved",
              "transition_id": "51",
              "description": "All linked PRs merged / issues closed"
            }
          ]
        },
        "bugzilla": {
          "issue_types": ["Bug", "Vulnerability"],
          "transition_rules": [
            {
              "from": "ASSIGNED",
              "to": "POST",
              "condition": "has_active_link",
              "transition_id": "31",
              "description": "PR opened or issue created"
            },
            {
              "from": "POST",
              "to": "MODIFIED",
              "condition": "all_links_resolved",
              "transition_id": "91",
              "description": "All linked PRs merged / issues closed"
            }
          ]
        }
      }
    }
  }
}
